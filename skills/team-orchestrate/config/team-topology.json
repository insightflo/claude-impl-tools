{
  "domainMapping": {
    "backend": "architecture-lead",
    "api": "architecture-lead",
    "architecture": "architecture-lead",
    "database": "architecture-lead",
    "shared": "architecture-lead",
    "frontend": "design-lead",
    "design": "design-lead",
    "ui": "design-lead",
    "ux": "design-lead",
    "test": "qa-lead",
    "quality": "qa-lead",
    "security": "qa-lead",
    "performance": "qa-lead"
  },
  "teammates": {
    "architecture-lead": {
      "executors": ["builder", "reviewer"],
      "domains": ["backend", "api", "architecture", "database", "shared"],
      "model": "opus"
    },
    "qa-lead": {
      "executors": ["reviewer", "test-specialist"],
      "domains": ["test", "quality", "security", "performance"],
      "model": "sonnet"
    },
    "design-lead": {
      "executors": ["designer", "builder"],
      "domains": ["frontend", "design", "ui", "ux"],
      "model": "sonnet"
    }
  },
  "defaultTeammate": "architecture-lead",
  "governance": {
    "planApprovalRequired": true,
    "hooks": {
      "TeammateIdle": "project-team/hooks/teammate-idle-gate.js",
      "TaskCompleted": "project-team/hooks/task-completed-gate.js"
    }
  }
}
