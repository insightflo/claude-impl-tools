{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Orchestrate State",
  "description": "State file for orchestrate-standalone resume capability",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "State format version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "started_at": {
      "type": "string",
      "format": "date-time",
      "description": "Orchestration start timestamp"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "Orchestration completion timestamp (null if in progress)"
    },
    "mode": {
      "type": "string",
      "enum": ["lite", "standard", "full"],
      "description": "Execution mode"
    },
    "current_layer": {
      "type": "integer",
      "minimum": 0,
      "description": "Current layer being executed"
    },
    "total_layers": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of layers"
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Task identifier (e.g., T1.1)"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "completed", "failed", "timeout", "skipped"],
            "description": "Task execution status"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task creation timestamp"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task last update timestamp"
          },
          "started_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task execution start timestamp"
          },
          "completed_at": {
            "type": "string",
            "format": "date-time",
            "description": "Task completion timestamp"
          },
          "duration": {
            "type": "number",
            "description": "Task execution duration in milliseconds"
          },
          "worker": {
            "type": "string",
            "description": "Worker ID that executed this task"
          },
          "error": {
            "type": "string",
            "description": "Error message if task failed"
          },
          "code": {
            "type": "integer",
            "description": "Exit code if task failed"
          },
          "output": {
            "type": "string",
            "description": "Task output (truncated)"
          }
        },
        "required": ["id", "status"]
      }
    }
  },
  "required": ["version", "started_at", "mode", "tasks"],
  "examples": [
    {
      "version": "1.0.0",
      "started_at": "2026-03-03T10:00:00Z",
      "mode": "standard",
      "current_layer": 2,
      "total_layers": 5,
      "tasks": [
        {
          "id": "T1.1",
          "status": "completed",
          "created_at": "2026-03-03T10:00:00Z",
          "updated_at": "2026-03-03T10:05:00Z",
          "started_at": "2026-03-03T10:00:10Z",
          "completed_at": "2026-03-03T10:05:00Z",
          "duration": 290000,
          "worker": "worker-1"
        },
        {
          "id": "T1.2",
          "status": "in_progress",
          "created_at": "2026-03-03T10:00:00Z",
          "updated_at": "2026-03-03T10:05:30Z",
          "started_at": "2026-03-03T10:05:00Z",
          "worker": "worker-2"
        },
        {
          "id": "T2.1",
          "status": "pending",
          "created_at": "2026-03-03T10:00:00Z",
          "updated_at": "2026-03-03T10:00:00Z"
        }
      ]
    }
  ]
}
